# OpenCode Dockerized User Configuration
# 
# This file is auto-generated by setup.sh but can be edited manually.
# Location: ~/.config/opencode-dockerized/config
#
# Format:
#   mount.<name>=<host_path>:<container_path>[:<mode>]
#   env.<name>=<VARIABLE_NAME>
#
# Modes: "ro" (read-only, default) or "rw" (read-write)
# Paths: Use ~ for home directory (expanded at runtime)
# Vars: Must be uppercase with underscores, set in host environment

# ============================================
# Custom Volume Mounts
# ============================================
# Syntax: mount.<name>=<host_path>:<container_path>[:<mode>]
#
# These paths are mounted into the container, allowing you to:
# - Use your global git configuration
# - Access SSH keys for authentication
# - Share API keys and credentials securely
#
# Examples:
#   mount.gitconfig=~/.gitconfig:/home/coder/.gitconfig
#   mount.gitignore=~/.config/git/gitignore_global:/home/coder/.config/git/gitignore_global
#   mount.ssh=~/.ssh:/home/coder/.ssh
#   mount.gradle=~/.gradle/gradle.properties:/home/coder/.gradle/gradle.properties

# mount.gitconfig=~/.gitconfig:/home/coder/.gitconfig
# mount.gitignore_global=~/.config/git/gitignore_global:/home/coder/.config/git/gitignore_global
# mount.ssh=~/.ssh:/home/coder/.ssh

# ============================================
# Environment Variables
# ============================================
# Syntax: env.<name>=<VARIABLE_NAME>
#
# These variables are passed from your host environment to the container.
# Useful for:
# - SSH connection info (for agent forwarding)
# - API keys and tokens
# - Build-related variables
#
# Only variables that are set in your host environment will be passed.
# If a variable is not set on the host, it will be skipped with a warning.
#
# Common examples:
#   env.ssh_auth=SSH_AUTH_SOCK           # SSH agent socket (agent forwarding)
#   env.ssh_client=SSH_CLIENT             # SSH client info
#   env.ssh_connection=SSH_CONNECTION     # SSH connection details
#   env.ssh_tty=SSH_TTY                   # SSH TTY info
#   env.aws_bedrock=AWS_BEARER_TOKEN_BEDROCK  # AWS credentials
#   env.context7=CONTEXT7_API_KEY         # Context7 API key

# env.ssh_auth_sock=SSH_AUTH_SOCK
# env.ssh_client=SSH_CLIENT
# env.ssh_connection=SSH_CONNECTION
# env.ssh_tty=SSH_TTY
# env.aws_bedrock=AWS_BEARER_TOKEN_BEDROCK
# env.context7=CONTEXT7_API_KEY
